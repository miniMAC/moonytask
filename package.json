{
  "name": "moonytask",
  "private": true,
  "version": "0.1.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "build:mac": "TAURI_SIGNING_PRIVATE_KEY_PATH=$HOME/.tauri/moonytask.key tauri build",
    "preandroid:apk": "command -v rustup >/dev/null 2>&1 || { echo 'rustup not found. Install rustup and ensure it is on PATH.'; exit 1; }",
    "android:apk": "node scripts/build-android-apk.mjs"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "i18next": "^26.3.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.8",
    "recharts": "^3.9.2",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "sharp": "^0.35.3",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
