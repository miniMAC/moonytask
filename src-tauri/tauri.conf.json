{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MoonyTask",
  "version": "0.1.3",
  "identifier": "com.minimamente.moonytask",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MoonyTask",
        "width": 1100,
        "height": 720,
        "minWidth": 860,
        "minHeight": 560,
        "dragDropEnabled": false
      },
      {
        "label": "popover",
        "title": "MoonyTask",
        "url": "index.html",
        "width": 360,
        "height": 540,
        "dragDropEnabled": false,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visibleOnAllWorkspaces": true,
        "visible": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "category": "Productivity",
    "shortDescription": "Project time tracker",
    "longDescription": "MoonyTask tracks the time you spend on your projects from the menu bar, with folders, reports, costs and Google Drive sync.",
    "publisher": "minimamente",
    "homepage": "https://moonytask.com",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "rpm": {
        "release": "1",
        "depends": [
          "libwebkit2gtk-4.1.so.0()(64bit)",
          "libgtk-3.so.0()(64bit)"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://moonytask.com/downloads/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMzMEEzNEI1QTA5RkZFOTgKUldTWS9wK2d0VFFLd3huUkMrMXFmUytyMWJFTmZxOEptbm1BdE5XdW96TEpaK3RLZ3gxTmZOUE0K"
    }
  }
}
