{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Tauri: dev",
      "type": "shell",
      "command": "npm",
      "args": ["run", "tauri", "dev"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Rust target: macOS Intel",
      "type": "shell",
      "command": "rustup",
      "args": ["target", "add", "x86_64-apple-darwin"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Build: macOS DMG universal",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "tauri",
        "--",
        "build",
        "--target",
        "universal-apple-darwin",
        "--bundles",
        "dmg"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": ["Rust target: macOS Intel"],
      "dependsOrder": "sequence",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
